<div class="row g-3 mb-3">
  <div class="col-lg-6">
    <div class="card h-100">
      <div class="card-header">Hauptkategorie anlegen</div>
      <div class="card-body">
        <form method="post" action="/admin/categories/create" enctype="multipart/form-data" class="row g-2">
          <div class="col-md-4"><input class="form-control" name="name" placeholder="Name" required /></div>
          <div class="col-md-3"><input class="form-control" name="slug" placeholder="Slug" /></div>
          <div class="col-md-3"><input class="form-control" type="file" name="image" accept="image/*" /></div>
          <div class="col-md-12"><textarea class="form-control" name="description" rows="2" placeholder="Kurze Beschreibung (optional)"></textarea></div>
          <div class="col-md-12"><textarea class="form-control" name="seo_text" rows="3" placeholder="SEO Text (optional)"></textarea></div>
          <div class="col-md-2 d-grid"><button class="btn btn-dark">Anlegen</button></div>
          <input type="hidden" name="parent_id" value="" />
        </form>
      </div>
    </div>
  </div>

  <div class="col-lg-6">
    <div class="card h-100">
      <div class="card-header">Unterkategorie anlegen</div>
      <div class="card-body">
        <form method="post" action="/admin/categories/create" enctype="multipart/form-data" class="row g-2">
          <div class="col-md-3"><input class="form-control" name="name" placeholder="Unterkategorie" required /></div>
          <div class="col-md-2"><input class="form-control" name="slug" placeholder="Slug" /></div>
          <div class="col-md-3">
            <select class="form-select" name="parent_id" required>
              <option value="">Parent wählen</option>
              <% data.rootCategories.forEach((cat) => { %>
                <option value="<%= cat.id %>"><%= cat.name %></option>
              <% }) %>
            </select>
          </div>
          <div class="col-md-2"><input class="form-control" type="file" name="image" accept="image/*" /></div>
          <div class="col-md-12"><textarea class="form-control" name="description" rows="2" placeholder="Kurze Beschreibung (optional)"></textarea></div>
          <div class="col-md-12"><textarea class="form-control" name="seo_text" rows="3" placeholder="SEO Text (optional)"></textarea></div>
          <div class="col-md-2 d-grid"><button class="btn btn-outline-primary">Anlegen</button></div>
        </form>
      </div>
    </div>
  </div>
</div>

<div class="card">
  <div class="card-header d-flex justify-content-between align-items-center">
    <span>Kategorien-Übersicht</span>
    <span class="small text-muted"><%= data.categories.length %> Einträge</span>
  </div>
  <div class="table-responsive">
    <table class="table align-middle mb-0">
      <thead>
        <tr>
          <th style="width:80px;">ID</th>
          <th>Name</th>
          <th>Slug</th>
          <th>Bild</th>
          <th>Typ</th>
          <th class="text-end">Aktionen</th>
        </tr>
      </thead>
      <tbody>
        <% if (!data.rootCategories.length) { %>
          <tr>
            <td colspan="6" class="text-center py-4 text-muted">Noch keine Kategorien angelegt.</td>
          </tr>
        <% } %>

        <% data.rootCategories.forEach((root) => { %>
          <tr class="table-light">
            <td><%= root.id %></td>
            <td><strong><%= root.name %></strong></td>
            <td><%= root.slug || '-' %></td>
            <td>
              <% if (root.image_path) { %>
                <img src="/admin<%= root.image_path %>" alt="<%= root.name %>" class="rounded border" style="width:56px;height:56px;object-fit:cover;" />
              <% } else { %>
                <span class="text-muted">-</span>
              <% } %>
            </td>
            <td><span class="badge text-bg-dark">Hauptkategorie</span></td>
            <td class="text-end">
              <div class="d-inline-flex gap-2">
                <button class="btn btn-sm btn-outline-secondary" type="button" data-bs-toggle="collapse" data-bs-target="#editCategory<%= root.id %>">Bearbeiten</button>
                <form method="post" action="/admin/categories/<%= root.id %>/delete" onsubmit="return confirm('Kategorie löschen? Unterkategorien werden auf Parent NULL gesetzt.')">
                  <button class="btn btn-sm btn-outline-danger">Löschen</button>
                </form>
              </div>
            </td>
          </tr>
          <tr class="collapse" id="editCategory<%= root.id %>">
            <td colspan="6" class="bg-body-tertiary">
              <form method="post" action="/admin/categories/<%= root.id %>/update" enctype="multipart/form-data" class="row g-2">
                <div class="col-md-3"><input class="form-control form-control-sm" name="name" value="<%= root.name %>" required /></div>
                <div class="col-md-2"><input class="form-control form-control-sm" name="slug" value="<%= root.slug || '' %>" /></div>
                <div class="col-md-3"><input class="form-control form-control-sm" type="file" name="image" accept="image/*" /></div>
                <div class="col-md-2">
                  <div class="form-check mt-1">
                    <input class="form-check-input" type="checkbox" name="remove_image" id="removeImageRoot<%= root.id %>" />
                    <label class="form-check-label small" for="removeImageRoot<%= root.id %>">Bild entfernen</label>
                  </div>
                </div>
                <input type="hidden" name="parent_id" value="" />
                <div class="col-md-12"><textarea class="form-control form-control-sm" name="description" rows="2" placeholder="Beschreibung"><%= root.description || '' %></textarea></div>
                <div class="col-md-12"><textarea class="form-control form-control-sm" name="seo_text" rows="3" placeholder="SEO Text"><%= root.seo_text || '' %></textarea></div>
                <div class="col-md-2 d-grid"><button class="btn btn-sm btn-dark">Speichern</button></div>
              </form>
            </td>
          </tr>

          <% (data.childrenByParent[root.id] || []).forEach((child) => { %>
            <tr>
              <td><%= child.id %></td>
              <td class="ps-4">&rarr; <%= child.name %></td>
              <td><%= child.slug || '-' %></td>
              <td>
                <% if (child.image_path) { %>
                  <img src="/admin<%= child.image_path %>" alt="<%= child.name %>" class="rounded border" style="width:56px;height:56px;object-fit:cover;" />
                <% } else { %>
                  <span class="text-muted">-</span>
                <% } %>
              </td>
              <td><span class="badge text-bg-secondary">Unterkategorie</span></td>
              <td class="text-end">
                <div class="d-inline-flex gap-2">
                  <button class="btn btn-sm btn-outline-secondary" type="button" data-bs-toggle="collapse" data-bs-target="#editCategory<%= child.id %>">Bearbeiten</button>
                  <form method="post" action="/admin/categories/<%= child.id %>/delete" onsubmit="return confirm('Unterkategorie löschen?')">
                    <button class="btn btn-sm btn-outline-danger">Löschen</button>
                  </form>
                </div>
              </td>
            </tr>
            <tr class="collapse" id="editCategory<%= child.id %>">
              <td colspan="6" class="bg-body-tertiary">
                <form method="post" action="/admin/categories/<%= child.id %>/update" enctype="multipart/form-data" class="row g-2">
                  <div class="col-md-3"><input class="form-control form-control-sm" name="name" value="<%= child.name %>" required /></div>
                  <div class="col-md-2"><input class="form-control form-control-sm" name="slug" value="<%= child.slug || '' %>" /></div>
                  <div class="col-md-3"><input class="form-control form-control-sm" type="file" name="image" accept="image/*" /></div>
                  <div class="col-md-2">
                    <div class="form-check mt-1">
                      <input class="form-check-input" type="checkbox" name="remove_image" id="removeImageChild<%= child.id %>" />
                      <label class="form-check-label small" for="removeImageChild<%= child.id %>">Bild entfernen</label>
                    </div>
                  </div>
                  <div class="col-md-2">
                    <select class="form-select form-select-sm" name="parent_id">
                      <option value="">Ohne Parent</option>
                      <% data.rootCategories.forEach((cat) => { %>
                        <option value="<%= cat.id %>" <%= Number(child.parent_id) === Number(cat.id) ? 'selected' : '' %>><%= cat.name %></option>
                      <% }) %>
                    </select>
                  </div>
                  <div class="col-md-12"><textarea class="form-control form-control-sm" name="description" rows="2" placeholder="Beschreibung"><%= child.description || '' %></textarea></div>
                  <div class="col-md-12"><textarea class="form-control form-control-sm" name="seo_text" rows="3" placeholder="SEO Text"><%= child.seo_text || '' %></textarea></div>
                  <div class="col-md-2 d-grid"><button class="btn btn-sm btn-dark">Speichern</button></div>
                </form>
              </td>
            </tr>
          <% }) %>

          <tr>
            <td colspan="6" class="bg-body-tertiary">
              <form method="post" action="/admin/categories/<%= root.id %>/subcategories/create" enctype="multipart/form-data" class="row g-2 align-items-center">
                <div class="col-md-4"><input class="form-control form-control-sm" name="name" placeholder="Unterkategorie für <%= root.name %>" required /></div>
                <div class="col-md-3"><input class="form-control form-control-sm" name="slug" placeholder="Slug" /></div>
                <div class="col-md-3"><input class="form-control form-control-sm" type="file" name="image" accept="image/*" /></div>
                <div class="col-md-12"><textarea class="form-control form-control-sm" name="description" rows="2" placeholder="Beschreibung (optional)"></textarea></div>
                <div class="col-md-12"><textarea class="form-control form-control-sm" name="seo_text" rows="3" placeholder="SEO Text (optional)"></textarea></div>
                <div class="col-md-2 d-grid"><button class="btn btn-sm btn-outline-primary">Unterkategorie hinzufügen</button></div>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

