<% const posts = data.posts || []; %>
<% const flash = data.flash || null; %>

<% if (flash) { %>
  <div class="alert alert-<%= flash.type %>"><%= flash.text %></div>
<% } %>

<div class="d-flex justify-content-between align-items-center mb-3">
  <p class="text-muted mb-0">Artikel für den Store-Magazinbereich (Startseite + /magazin)</p>
  <a href="/admin/blog/new" class="btn btn-dark"><i class="bi bi-plus-lg"></i> Neuer Artikel</a>
</div>

<div class="card shadow-sm">
  <div class="table-responsive">
    <table class="table align-middle mb-0">
      <thead>
        <tr>
          <th>Artikel</th>
          <th>Status</th>
          <th>Autor</th>
          <th>Lesezeit</th>
          <th>Datum</th>
          <th class="text-end">Aktionen</th>
        </tr>
      </thead>
      <tbody>
        <% if (!posts.length) { %>
          <tr><td colspan="6" class="text-muted">Noch keine Blog Artikel vorhanden.</td></tr>
        <% } %>
        <% posts.forEach((post) => { %>
          <tr>
            <td>
              <div class="fw-semibold"><%= post.title %></div>
              <div class="small text-muted"><%= post.slug %></div>
              <% if (post.category_label) { %><span class="badge text-bg-light border mt-1"><%= post.category_label %></span><% } %>
            </td>
            <td>
              <% if (Number(post.is_published) === 1) { %>
                <span class="badge text-bg-success">veröffentlicht</span>
              <% } else { %>
                <span class="badge text-bg-secondary">Entwurf</span>
              <% } %>
              <% if (Number(post.is_featured) === 1) { %>
                <span class="badge text-bg-warning text-dark">Featured</span>
              <% } %>
            </td>
            <td><%= post.author_name || '-' %></td>
            <td><%= Number(post.read_time_minutes || 0) %> Min.</td>
            <td><%= post.published_at ? new Date(post.published_at).toLocaleString('de-AT') : '-' %></td>
            <td class="text-end">
              <div class="btn-group btn-group-sm">
                <a class="btn btn-outline-secondary" href="/magazin/<%= encodeURIComponent(post.slug) %>" target="_blank" rel="noopener">View</a>
                <a class="btn btn-outline-primary" href="/admin/blog/<%= post.id %>/edit">Bearbeiten</a>
                <form method="post" action="/admin/blog/<%= post.id %>/delete" onsubmit="return confirm('Artikel wirklich löschen?')" class="d-inline">
                  <button class="btn btn-outline-danger" type="submit">Löschen</button>
                </form>
              </div>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>
