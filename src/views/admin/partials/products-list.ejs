<div class="d-flex justify-content-between align-items-center mb-3">
  <div>
    <div class="text-muted small">Produktübersicht</div>
    <div class="small"><strong><%= data.products.length %></strong> Produkte insgesamt</div>
  </div>
  <a class="btn btn-dark" href="/admin/products/new">
    <i class="bi bi-plus-lg"></i> Produkt hinzufügen
  </a>
</div>

<div class="card">
  <div class="table-responsive">
    <table class="table align-middle mb-0">
      <thead>
        <tr>
          <th style="width: 80px;">Bild</th>
          <th>Titel</th>
          <th>SKU</th>
          <th>Preis</th>
          <th>Lager</th>
          <th>Kategorie</th>
          <th>Bestseller</th>
          <th>SEO</th>
          <th>Status</th>
          <th class="text-end">Aktionen</th>
        </tr>
      </thead>
      <tbody>
        <% if (!data.products.length) { %>
          <tr>
            <td colspan="10" class="text-center py-4 text-muted">Noch keine Produkte vorhanden.</td>
          </tr>
        <% } %>
        <% data.products.forEach((product) => { %>
          <tr>
            <td>
              <% if (product.featured_image) { %>
                <img src="/admin<%= product.featured_image %>" alt="" class="rounded border" style="width:56px;height:56px;object-fit:cover;" />
              <% } else { %>
                <div class="rounded border d-flex align-items-center justify-content-center text-muted" style="width:56px;height:56px;">-</div>
              <% } %>
            </td>
            <td>
              <div class="fw-semibold"><%= product.title %></div>
              <a href="/admin/products/<%= product.id %>/edit" class="small text-decoration-none">Bearbeiten</a>
            </td>
            <td><%= product.sku || '-' %></td>
            <td><%= Number(product.price).toFixed(2) %> EUR</td>
            <td><%= product.stock %></td>
            <td><%= product.category_name || '-' %></td>
            <td>
              <form method="post" action="/admin/products/<%= product.id %>/bestseller" class="m-0">
                <input type="hidden" name="is_bestseller" value="<%= product.is_bestseller ? 0 : 1 %>" />
                <button class="btn btn-sm <%= product.is_bestseller ? 'btn-warning' : 'btn-outline-secondary' %>" type="submit">
                  <%= product.is_bestseller ? 'Ja' : 'Nein' %>
                </button>
              </form>
            </td>
            <td>
              <% if (product.seo_title || product.seo_description) { %>
                <span class="badge text-bg-success">SEO gepflegt</span>
              <% } else { %>
                <span class="badge text-bg-warning">SEO fehlt</span>
              <% } %>
            </td>
            <td>
              <span class="badge <%= product.is_active ? 'text-bg-success' : 'text-bg-secondary' %>">
                <%= product.is_active ? 'aktiv' : 'inaktiv' %>
              </span>
            </td>
            <td class="text-end">
              <div class="d-inline-flex gap-2">
                <a class="btn btn-sm btn-outline-primary" href="/admin/products/<%= product.id %>/edit">Bearbeiten</a>
                <form method="post" action="/admin/products/<%= product.id %>/delete" onsubmit="return confirm('Produkt löschen?')">
                  <button class="btn btn-sm btn-outline-danger">Löschen</button>
                </form>
              </div>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>
