<div class="card mb-3">
  <div class="card-body">
    <form method="post" action="/admin/coupons/create" class="row g-2">
      <div class="col-md-3"><input class="form-control" name="code" placeholder="Code" required /></div>
      <div class="col-md-2">
        <select class="form-select" name="type"><option value="percent">%</option><option value="fixed">Fix</option></select>
      </div>
      <div class="col-md-2"><input class="form-control" type="number" step="0.01" name="value" placeholder="Wert" required /></div>
      <div class="col-md-2"><input class="form-control" type="number" name="usage_limit" placeholder="Limit" /></div>
      <div class="col-md-2 form-check d-flex align-items-center gap-2"><input class="form-check-input" type="checkbox" name="is_active" checked /><label class="form-check-label">Aktiv</label></div>
      <div class="col-md-1 d-grid"><button class="btn btn-dark">+ </button></div>
    </form>
  </div>
</div>

<div class="card">
  <div class="table-responsive">
    <table class="table table-sm align-middle mb-0">
      <thead><tr><th>Code</th><th>Typ</th><th>Wert</th><th>Limit</th><th>Verwendet</th><th>Status</th><th></th></tr></thead>
      <tbody>
        <% data.coupons.forEach((coupon) => { %>
          <tr>
            <td><%= coupon.code %></td>
            <td><%= coupon.type %></td>
            <td><%= Number(coupon.value).toFixed(2) %></td>
            <td><%= coupon.usage_limit || '-' %></td>
            <td><%= coupon.used_count %></td>
            <td><span class="badge <%= coupon.is_active ? 'text-bg-success' : 'text-bg-secondary' %>"><%= coupon.is_active ? 'aktiv' : 'inaktiv' %></span></td>
            <td>
              <form method="post" action="/admin/coupons/<%= coupon.id %>/delete" onsubmit="return confirm('Gutschein löschen?')">
                <button class="btn btn-sm btn-outline-danger">Löschen</button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

