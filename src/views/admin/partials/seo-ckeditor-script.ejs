<script src="https://cdn.ckeditor.com/ckeditor5/41.4.2/classic/ckeditor.js"></script>
<script>
  (function () {
    const textarea = document.querySelector('textarea[name="seo_text"]');
    if (!textarea || textarea.dataset.ckeditorInit === '1') return;
    textarea.dataset.ckeditorInit = '1';

    ClassicEditor.create(textarea, {
      toolbar: [
        'heading',
        '|',
        'bold',
        'italic',
        'link',
        '|',
        'bulletedList',
        'numberedList',
        '|',
        'undo',
        'redo'
      ],
      heading: {
        options: [
          { model: 'paragraph', title: 'Absatz', class: 'ck-heading_paragraph' },
          { model: 'heading3', view: 'h3', title: 'Überschrift 3', class: 'ck-heading_heading3' },
          { model: 'heading4', view: 'h4', title: 'Überschrift 4', class: 'ck-heading_heading4' }
        ]
      }
    }).then((editor) => {
      window.__seoEditor = editor;
      const form = textarea.closest('form');
      if (!form) return;
      form.addEventListener('submit', () => {
        textarea.value = editor.getData();
      });
    }).catch((error) => {
      console.error('[SEO] CKEditor init failed:', error);
    });
  })();
</script>
