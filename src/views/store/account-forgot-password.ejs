<!DOCTYPE html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <%- include('./partials/head-seo', { title, seoMeta: (typeof seoMeta !== 'undefined' ? seoMeta : null) }) %>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600&family=Montserrat:wght@300;400;500;600&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="/css/store.css" />
  </head>
  <body>
    <%- include('./partials/header', { hideOnTop: false }) %>
    <main class="section checkout-page account-page">
      <h1>Passwort vergessen</h1>
      <% if (error) { %><div class="checkout-error"><%= error %></div><% } %>
      <% if (success) { %><div class="checkout-success-note"><%= success %></div><% } %>
      <section class="account-card">
        <h3>Reset-Link anfordern</h3>
        <form method="post" action="/account/forgot-password" class="checkout-form account-form">
          <div class="checkout-grid">
            <input name="email" type="email" placeholder="E-Mail" required />
          </div>
          <button type="submit" class="btn-solid">Reset-Link senden</button>
          <a href="/account" class="account-auth-link">Zurück zum Konto</a>
        </form>
      </section>
      <%- include('./partials/seo-bottom', { seoBottom: (typeof seoBottom !== 'undefined' ? seoBottom : null) }) %>
    </main>
    <%- include('./partials/footer') %>
    <script>
      window.__STORE_DATA__ = { searchItems: <%- JSON.stringify(searchItems).replace(/</g, '\\u003c') %>, initialQuery: "" };
    </script>
    <script src="/js/store.js"></script>
  </body>
</html>
