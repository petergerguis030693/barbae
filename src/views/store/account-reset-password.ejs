<!DOCTYPE html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <%- include('./partials/head-seo', { title, seoMeta: (typeof seoMeta !== 'undefined' ? seoMeta : null) }) %>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600&family=Montserrat:wght@300;400;500;600&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="/css/store.css" />
  </head>
  <body>
    <%- include('./partials/header', { hideOnTop: false }) %>
    <main class="section checkout-page account-page">
      <h1>Passwort zurücksetzen</h1>
      <% if (error) { %><div class="checkout-error"><%= error %></div><% } %>
      <% if (success) { %><div class="checkout-success-note"><%= success %></div><% } %>

      <section class="account-card">
        <h3>Neues Passwort</h3>
        <% if (!tokenValid) { %>
          <p>Der Reset-Link ist ungültig oder abgelaufen.</p>
          <a href="/account/forgot-password" class="btn-outline account-inline-btn">Neuen Link anfordern</a>
        <% } else { %>
          <form method="post" action="/account/reset-password" class="checkout-form account-form">
            <input type="hidden" name="token" value="<%= token %>" />
            <div class="checkout-grid">
              <input name="password" type="password" placeholder="Neues Passwort" required />
              <input name="password_confirm" type="password" placeholder="Passwort wiederholen" required />
            </div>
            <button type="submit" class="btn-solid">Passwort speichern</button>
          </form>
        <% } %>
      </section>
      <%- include('./partials/seo-bottom', { seoBottom: (typeof seoBottom !== 'undefined' ? seoBottom : null) }) %>
    </main>
    <%- include('./partials/footer') %>
    <script>
      window.__STORE_DATA__ = { searchItems: <%- JSON.stringify(searchItems).replace(/</g, '\\u003c') %>, initialQuery: "" };
    </script>
    <script src="/js/store.js"></script>
  </body>
</html>
