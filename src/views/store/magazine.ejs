<!DOCTYPE html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <%- include('./partials/head-seo', { title, seoMeta: (typeof seoMeta !== 'undefined' ? seoMeta : null) }) %>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600&family=Montserrat:wght@300;400;500;600&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="/css/store.css" />
  </head>
  <body>
    <%- include('./partials/header', { hideOnTop: false }) %>
    <main class="section magazine-page">
      <div class="section-head magazine-page-head">
        <div>
          <p class="eyebrow">BarBae Magazin</p>
          <h1>Wissenswertes aus Beauty, Styles & curated Looks</h1>
        </div>
      </div>

      <% if (!posts || !posts.length) { %>
        <p class="magazine-empty">Noch keine Artikel veröffentlicht.</p>
      <% } else { %>
        <div class="magazine-page-grid">
          <% posts.forEach((post, index) => { %>
            <article class="magazine-card <%= index < 2 ? 'magazine-card-lg' : 'magazine-card-sm' %>">
              <a class="magazine-card-media" href="<%= post.blogUrl %>">
                <img src="<%= post.heroImageUrl %>" alt="<%= post.cover_image_alt || post.title %>" loading="lazy" />
              </a>
              <div class="magazine-card-body">
                <p class="magazine-meta-top"><%= post.category_label || 'BarBae Magazin' %></p>
                <h4><a href="<%= post.blogUrl %>"><%= post.title %></a></h4>
                <% if (post.excerpt) { %><p class="magazine-excerpt"><%= post.excerpt %></p><% } %>
                <div class="magazine-meta-row">
                  <span><%= post.author_name || 'BarBae Redaktion' %></span>
                  <span><i class="bi bi-clock"></i> <%= Number(post.read_time_minutes || 0) %> Min.</span>
                </div>
              </div>
            </article>
          <% }) %>
        </div>
      <% } %>
    </main>

    <%- include('./partials/footer') %>
    <script>
      window.__STORE_DATA__ = {
        searchItems: <%- JSON.stringify(searchItems).replace(/</g, '\\u003c') %>,
        initialQuery: ""
      };
    </script>
    <script src="/js/store.js"></script>
  </body>
</html>
