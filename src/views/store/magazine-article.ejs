<!DOCTYPE html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <%- include('./partials/head-seo', { title, seoMeta: (typeof seoMeta !== 'undefined' ? seoMeta : null) }) %>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600&family=Montserrat:wght@300;400;500;600&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="/css/store.css" />
  </head>
  <body>
    <%- include('./partials/header', { hideOnTop: false }) %>
    <main class="section magazine-article-page">
      <a class="product-back" href="/magazin"><i class="bi bi-arrow-left"></i> Zurück zum Magazin</a>

      <article class="magazine-article">
        <header class="magazine-article-header">
          <p class="magazine-meta-top"><%= article.category_label || 'BarBae Magazin' %></p>
          <h1><%= article.title %></h1>
          <div class="magazine-meta-row">
            <span><%= article.author_name || 'BarBae Redaktion' %><% if (article.author_role) { %> · <%= article.author_role %><% } %></span>
            <span><i class="bi bi-clock"></i> <%= Number(article.read_time_minutes || 0) %> Min.</span>
          </div>
        </header>

        <figure class="magazine-article-hero">
          <img src="<%= article.heroImageUrl %>" alt="<%= article.cover_image_alt || article.title %>" />
        </figure>

        <% if (article.excerpt) { %>
          <p class="magazine-article-excerpt"><%= article.excerpt %></p>
        <% } %>

        <div class="magazine-article-content"><%- article.contentHtml %></div>
      </article>

      <% if (relatedPosts && relatedPosts.length) { %>
        <section class="magazine-related">
          <div class="section-head">
            <h3>Weitere Artikel</h3>
          </div>
          <div class="magazine-mini-grid">
            <% relatedPosts.forEach((post) => { %>
              <article class="magazine-card magazine-card-sm">
                <a class="magazine-card-media" href="<%= post.blogUrl %>">
                  <img src="<%= post.heroImageUrl %>" alt="<%= post.cover_image_alt || post.title %>" loading="lazy" />
                </a>
                <div class="magazine-card-body">
                  <p class="magazine-meta-top"><%= post.category_label || 'BarBae Magazin' %></p>
                  <h4><a href="<%= post.blogUrl %>"><%= post.title %></a></h4>
                  <div class="magazine-meta-row">
                    <span><%= post.author_name || 'BarBae Redaktion' %></span>
                    <span><i class="bi bi-clock"></i> <%= Number(post.read_time_minutes || 0) %> Min.</span>
                  </div>
                </div>
              </article>
            <% }) %>
          </div>
        </section>
      <% } %>
    </main>

    <%- include('./partials/footer') %>
    <script>
      window.__STORE_DATA__ = {
        searchItems: <%- JSON.stringify(searchItems).replace(/</g, '\\u003c') %>,
        initialQuery: ""
      };
    </script>
    <script src="/js/store.js"></script>
  </body>
</html>
