<!DOCTYPE html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %> | Adminpanel</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link href="/admin/css/admin.css" rel="stylesheet" />
  </head>
  <body>
    <div class="d-flex min-vh-100">
      <aside id="adminSidebar" class="admin-sidebar border-end">
        <div class="d-flex align-items-center justify-content-between p-3 border-bottom">
          <strong class="sidebar-brand">Shop Admin</strong>
          <button class="btn btn-sm btn-outline-secondary sidebar-toggle" type="button" id="sidebarToggle" aria-label="Sidebar umschalten">
            <i class="bi bi-layout-sidebar"></i>
          </button>
        </div>

        <div id="sidebarMenu" class="show">
          <nav class="nav flex-column p-2 gap-1">
            <a class="nav-link <%= activeMenu === 'dashboard' ? 'active' : '' %>" href="/admin/dashboard"><i class="bi bi-speedometer2"></i><span class="menu-label">Dashboard</span></a>
            <a class="nav-link <%= activeMenu === 'categories' ? 'active' : '' %>" href="/admin/categories"><i class="bi bi-diagram-3"></i><span class="menu-label">Kategorien</span></a>
            <a class="nav-link <%= activeMenu === 'products' ? 'active' : '' %>" href="/admin/products"><i class="bi bi-box-seam"></i><span class="menu-label">Produkte</span></a>
            <a class="nav-link <%= activeMenu === 'product-options' ? 'active' : '' %>" href="/admin/product-options"><i class="bi bi-sliders"></i><span class="menu-label">Produktoptionen</span></a>
            <a class="nav-link <%= activeMenu === 'inventory' ? 'active' : '' %>" href="/admin/inventory"><i class="bi bi-stack"></i><span class="menu-label">Lager</span></a>
            <a class="nav-link <%= activeMenu === 'orders' ? 'active' : '' %>" href="/admin/orders"><i class="bi bi-receipt"></i><span class="menu-label">Bestellungen</span></a>
            <a class="nav-link <%= activeMenu === 'customers' ? 'active' : '' %>" href="/admin/customers"><i class="bi bi-people"></i><span class="menu-label">Kunden</span></a>
            <a class="nav-link <%= activeMenu === 'coupons' ? 'active' : '' %>" href="/admin/coupons"><i class="bi bi-ticket-perforated"></i><span class="menu-label">Gutscheine</span></a>
            <a class="nav-link <%= activeMenu === 'invoices' ? 'active' : '' %>" href="/admin/invoices"><i class="bi bi-file-earmark-pdf"></i><span class="menu-label">Rechnungen</span></a>
            <a class="nav-link <%= activeMenu === 'email-logs' ? 'active' : '' %>" href="/admin/email-logs"><i class="bi bi-envelope"></i><span class="menu-label">E-Mail-Logs</span></a>
            <a class="nav-link <%= activeMenu === 'customer-messages' ? 'active' : '' %>" href="/admin/customer-messages"><i class="bi bi-megaphone"></i><span class="menu-label">Kunden Nachrichten</span></a>
            <a class="nav-link <%= activeMenu === 'blog' ? 'active' : '' %>" href="/admin/blog"><i class="bi bi-journal-richtext"></i><span class="menu-label">Magazin Blog</span></a>
            <a class="nav-link <%= activeMenu === 'seo' ? 'active' : '' %>" href="/admin/seo"><i class="bi bi-search"></i><span class="menu-label">SEO Texte</span></a>
            <a class="nav-link <%= activeMenu === 'settings' ? 'active' : '' %>" href="/admin/settings"><i class="bi bi-gear"></i><span class="menu-label">Einstellungen</span></a>
            <a class="nav-link text-danger" href="/admin/logout"><i class="bi bi-box-arrow-right"></i><span class="menu-label">Logout</span></a>
          </nav>
        </div>
      </aside>

      <main class="flex-grow-1 p-3 p-lg-4">
        <div class="d-flex justify-content-between align-items-center mb-3">
          <h1 class="h4 mb-0"><%= title %></h1>
          <span class="text-muted small">Eingeloggt als <strong><%= adminUser?.name || '-' %></strong></span>
        </div>

        <%- include(`../admin/partials/${body}`) %>
      </main>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
      (function () {
        const storageKey = 'adminSidebarCollapsed';
        const sidebar = document.getElementById('adminSidebar');
        const toggle = document.getElementById('sidebarToggle');
        if (!sidebar || !toggle) return;

        const applyState = (collapsed) => {
          sidebar.classList.toggle('collapsed', collapsed);
        };

        const saved = localStorage.getItem(storageKey);
        applyState(saved === '1');

        toggle.addEventListener('click', () => {
          const collapsed = !sidebar.classList.contains('collapsed');
          applyState(collapsed);
          localStorage.setItem(storageKey, collapsed ? '1' : '0');
        });
      })();
    </script>
  </body>
</html>
