  <section id="mehrwert" class="mehrwert">
    <div class="container-mehrwert">
      <h2 class="section-title">Unser Mehrwert für dein Unternehmen</h2>

      <div class="mehrwert-grid">
        <div class="mw-item">
          <i class="fas fa-chart-line icon"></i>
          <h3>Messbare Ergebnisse</h3>
          <p>Wir liefern Lösungen, die Umsatz, Effizienz und Markenbekanntheit steigern – nicht nur schöne Designs.</p>
        </div>

        <div class="mw-item">
          <i class="fas fa-brain icon"></i>
          <h3>Strategische Intelligenz</h3>
          <p>Unsere KI-gestützten Systeme treffen datenbasierte Entscheidungen – schnell, präzise und skalierbar.</p>
        </div>

        <div class="mw-item">
          <i class="fas fa-users icon"></i>
          <h3>Partnerschaftlich</h3>
          <p>Wir begleiten dich langfristig – von der Idee bis zur Umsetzung und Automatisierung deiner
            Geschäftsprozesse.</p>
        </div>
      </div>
    </div>
  </section>


  <section id="projekte" class="projekte">
    <div class="container-projekte">
      <h2 class="section-title">Unsere Projekte</h2>
      <p class="section-subtitle">Ein Auszug unserer Arbeit – Qualität vor Quantität.</p>

      <div class="projekte-grid">
        <% const projekte=[ { img: "/images/projekt1.jpg" , title: "FinTech Plattform" ,
          desc: "KI-gestützte Finanzanalyse & Automatisierung" }, { img: "/images/projekt2.jpg" ,
          title: "SmartCity Dashboard" , desc: "Echtzeitdaten & städtische Vernetzung" }, { img: "/images/projekt3.jpg"
          , title: "Healthcare KI" , desc: "Automatische Diagnostik & Patientenverwaltung" }, {
          img: "/images/projekt4.jpg" , title: "E-Commerce Automatisierung" ,
          desc: "Shop-Management & Prozessoptimierung" }, { img: "/images/projekt5.jpg" , title: "CRM System" ,
          desc: "Kundendatenanalyse & Automatisierte Workflows" } ]; %>

          <% projekte.forEach(p=> { %>
            <div class="projekt-box fade-in">
              <img src="<%= p.img %>" alt="<%= p.title %>">
              <div class="projekt-info">
                <h3>
                  <%= p.title %>
                </h3>
                <p>
                  <%= p.desc %>
                </p>
              </div>
            </div>
            <% }); %>
      </div>
    </div>
  </section>



