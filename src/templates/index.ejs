  <section class="hero">
    <video autoplay muted loop playsinline class="hero-video">
      <source src="/images/hero.mp4" type="video/mp4">
      <img src="/images/hero-fallback.jpg" alt="ITWELT24 – Digitale Zukunft" />
    </video>

    <!-- Overlay (dunkler Filter für besseren Kontrast) -->
    <div class="overlay"></div>

    <!-- Hero-Content -->
    <div class="hero-content">
      <p>ITWELT24 – Full-Service-Agentur für IT, Software, Apps & Webentwicklung</p>
      <a href="#kontakt" class="btn">Projekt starten</a>
    </div>

  </section>

<div class="leistungen-slider-container">
  <div class="slide">

    <div class="item" style="background-image: url('/images/it&network.jpg');">
      <div class="content">
        <div class="name">IT & Network</div>
        <div class="des">Professionelle IT-Infrastruktur, sichere Netzwerke & Unternehmenssupport.</div>
      </div>
    </div>

    <div class="item" style="background-image: url('/images/cloud&hosting.jpg');">
      <div class="content">
        <div class="name">Cloud & Hosting</div>
        <div class="des">Private Cloud, Serververwaltung & Hochverfügbarkeit auf Enterprise-Niveau.</div>
      </div>
    </div>

    <div class="item" style="background-image: url('/images/ki.jpg');">
      <div class="content">
        <div class="name">Künstliche Intelligenz</div>
        <div class="des">Automatisierung, Chatbots & intelligente Prozessoptimierung.</div>
      </div>
    </div>

    <div class="item" style="background-image: url('/images/brands.png');">
      <div class="content">
        <div class="name">Branding & Design</div>
        <div class="des">Wir gestalten Marken, die Vertrauen schaffen und modern wirken.</div>
      </div>
    </div>

    <div class="item" style="background-image: url('/images/software-entwicklung.jpg');">
      <div class="content">
        <div class="name">Software Entwicklung</div>
        <div class="des">Individuelle Softwarelösungen abgestimmt auf echte Geschäftsprozesse.</div>
      </div>
    </div>

    <div class="item" style="background-image: url('/images/Webentwicklung.jpg');">
      <div class="content">
        <div class="name">Webentwicklung</div>
        <div class="des">Moderne Web-Apps & Websites mit Fokus Performance & Design.</div>
      </div>
    </div>

  </div>

  <div class="slider-buttons">
    <button class="prev">&#9665;</button>
    <button class="next">&#9655;</button>
  </div>
</div>

  <section id="leistungen" class="leistungen">
